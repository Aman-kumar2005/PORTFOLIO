{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
     "types": ["node"],
    "lib": ["ES2020","DOM"],
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": false,
    "sourceMap": true,
    "noImplicitAny": true,
    "paths": {
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}